{
  "name": "@netflix-deadline/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --test-scheduled --port 8787",
    "deploy": "npm run build -w @netflix-deadline/web && wrangler deploy",
    "deploy:staging": "npm run build -w @netflix-deadline/web && wrangler deploy --env staging",
    "typecheck": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply netflix-deadline-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply netflix-deadline-db --remote",
    "db:migrate:remote:staging": "wrangler d1 migrations apply netflix-deadline-db-staging --env staging --remote"
  },
  "dependencies": {
    "@netflix-deadline/shared": "*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  }
}
